{
  "name": "browserless-mcp",
  "version": "2.0.0",
  "description": "Model Context Protocol server for Browserless (v2) browser automation",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "browserless-mcp": "dist/index.js",
    "browserless-mcp-simple": "dist/simple-server.js"
  },
  "files": [
    "dist",
    "README.md",
    "env.example",
    "config.json",
    "smithery.yaml"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js",
    "start:stdio": "node dist/index.js stdio",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts",
    "dev:stdio": "tsx src/index.ts stdio",
    "test": "node test-fill-dev.mjs",
    "test:mcp": "node test-mcp-stdio.mjs",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "mcp",
    "browserless",
    "puppeteer",
    "playwright",
    "browser-automation",
    "web-scraping"
  ],
  "author": "Lizzard Solutions",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.0",
    "ws": "^8.14.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
