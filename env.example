# Browserless Configuration
# Option A: a full base URL (recommended, works behind reverse proxies / custom domains)
BROWSERLESS_URL=http://localhost:3000

# Option B: host/port/protocol (used only when BROWSERLESS_URL is not set)
BROWSERLESS_HOST=localhost
BROWSERLESS_PORT=3000
BROWSERLESS_PROTOCOL=http

# Authentication token (required)
BROWSERLESS_TOKEN=your-secure-token-here

# Request timeout in milliseconds (client side)
BROWSERLESS_TIMEOUT=120000

# Max concurrent sessions (informational)
BROWSERLESS_CONCURRENT=5

# Directory where generated PDFs / screenshots / downloads are written
# Defaults to <os tmpdir>/browserless-mcp
# BROWSERLESS_OUTPUT_DIR=/path/to/output
