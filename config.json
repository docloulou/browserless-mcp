{
  "browserless": {
    "url": "http://localhost:3000",
    "token": null,
    "timeout": 120000,
    "concurrent": 5,
    "apiVersion": "2.x (Browserless v2 / chromium build)"
  },
  "endpoints": {
    "content": "/content",
    "screenshot": "/screenshot",
    "pdf": "/pdf",
    "function": "/function",
    "download": "/download",
    "scrape": "/scrape",
    "performance": "/performance",
    "active": "/active",
    "meta": "/meta",
    "sessions": "/sessions",
    "config": "/config",
    "metrics": "/metrics",
    "websocketChromium": "/chromium",
    "websocketPlaywright": "/chromium/playwright"
  },
  "testResults": {
    "content": true,
    "screenshot": true,
    "pdf": true,
    "function": true,
    "scrape": true,
    "performance": true,
    "download": true,
    "health": true,
    "sessions": true,
    "config": true,
    "metrics": true,
    "websocket": true
  },
  "notes": [
    "Verified against https://fill.dev/ on a live Browserless v2 instance (API 2.51.2).",
    "REST endpoints use the backwards-compatible aliases (/content, /pdf, ...) which map to /chromium/* on v2.",
    "Authentication is passed as a ?token= query parameter.",
    "/export, /unblock and /chromium/bql are NOT part of this build and were removed from the MCP."
  ]
}
